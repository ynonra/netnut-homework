// Prisma schema for the usage-based billing system.
//
// Money is stored as INTEGER minor units everywhere (never floats) — see CONTEXT.md
// "Resolved policy" and docs/adr/0001. Most models use cuid() ids; the high-write,
// cursor-paginated LedgerEntry will use an autoincrement Int id (docs/adr/0004) when
// it is introduced in a later slice.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl targets cover the Alpine container image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A thing a Customer can consume. Has a Name and a Unit Price (Credits per unit).
/// unitPrice is in integer minor units (e.g. cents) — never a float.
model Product {
  id        String   @id @default(cuid())
  name      String
  /// Unit Price: cost in minor units (e.g. cents) of consuming one unit.
  unitPrice Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The account that owns a Wallet and generates Consumption Events. The unit of
/// billing and isolation (CONTEXT.md). The Wallet is collapsed onto the Customer
/// (exactly one Wallet per Customer), so the spendable Balance lives here.
///
/// `balance` is the current Balance in integer minor units (e.g. cents) — never a
/// float. It may never go negative: the atomic deduction guard (docs/adr/0001)
/// enforces this primarily, and a CHECK (balance >= 0) constraint — added via raw
/// SQL in the migration, since Prisma cannot model it natively — defends it at the
/// database level.
model Customer {
  id        String   @id @default(cuid())
  name      String
  /// Current Balance in minor units. Atomically decremented on consumption
  /// (docs/adr/0001); CHECK (balance >= 0) guards against ever going negative.
  balance   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
