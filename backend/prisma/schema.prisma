// Prisma schema for the usage-based billing system.
//
// Money is stored as INTEGER minor units everywhere (never floats) — see CONTEXT.md
// "Resolved policy" and docs/adr/0001. Most models use cuid() ids; the high-write,
// cursor-paginated LedgerEntry uses an autoincrement Int id (docs/adr/0004).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl targets cover the Alpine container image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A thing a Customer can consume. Has a Name and a Unit Price (Credits per unit).
/// unitPrice is in integer minor units (e.g. cents) — never a float.
model Product {
  id        String   @id @default(cuid())
  name      String
  /// Unit Price: cost in minor units (e.g. cents) of consuming one unit.
  unitPrice Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The account that owns a Wallet and generates Consumption Events. The unit of
/// billing and isolation (CONTEXT.md). The Wallet is collapsed onto the Customer
/// (exactly one Wallet per Customer), so the spendable Balance lives here.
///
/// `balance` is the current Balance in integer minor units (e.g. cents) — never a
/// float. It may never go negative: the atomic deduction guard (docs/adr/0001)
/// enforces this primarily, and a CHECK (balance >= 0) constraint — added via raw
/// SQL in the migration, since Prisma cannot model it natively — defends it at the
/// database level.
model Customer {
  id        String   @id @default(cuid())
  name      String
  /// Current Balance in minor units. Atomically decremented on consumption
  /// (docs/adr/0001); CHECK (balance >= 0) guards against ever going negative.
  balance   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries LedgerEntry[]
}

/// A recorded historical row capturing a Consumption Event (and later, a Top-up)
/// for audit and history (CONTEXT.md "Usage Event"). Append-only; the Balance is
/// kept consistent with the ledger by writing this row in the same transaction as
/// the atomic deduction (docs/adr/0001).
///
/// Unlike the other models, this uses an autoincrement Int primary key: it is the
/// one high-write, cursor-paginated table, and a monotonic sortable id is a stable
/// pagination tiebreaker that cuid() cannot provide (docs/adr/0004). The compound
/// index on (customerId, createdAt) backs the newest-first history seek.
///
/// `amount` and `cost` are in integer minor units (e.g. cents) — never floats.
///
/// `idempotencyKey` is a client-minted UUID carried on a single logical
/// consumption submission and reused across its retries (docs/adr/0002). It is
/// `@unique`: inserting a row with a duplicate key inside the consume transaction
/// throws a unique-constraint violation, and that violation *is* the "already
/// processed" signal — caught and treated as a replay so no second deduction
/// occurs. The header is optional, so the column is nullable; omitted requests
/// store NULL and are not deduped (SQLite treats each NULL as distinct in a
/// UNIQUE index, so multiple NULLs coexist freely).
model LedgerEntry {
  id         Int               @id @default(autoincrement())
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id])
  /// CONSUMPTION (this slice) or, later, TOPUP. Stored as a string for SQLite.
  type       String
  /// Client-minted idempotency key for the originating submission (docs/adr/0002).
  /// Unique so a replayed key collides and is treated as a replay; nullable so
  /// omitted (header-less) requests are processed normally without dedup.
  idempotencyKey String?       @unique
  /// The Product consumed (null for non-consumption entries such as top-ups).
  productId  String?
  /// Units consumed in this event (null for non-consumption entries).
  quantity   Int?
  /// Unit Price captured at the time of the event, in minor units. Snapshotted so
  /// history stays correct even if the Product's price later changes.
  unitPrice  Int?
  /// Signed change to the Balance in minor units: negative for a consumption
  /// deduction, positive for a top-up. cost = -amount for a consumption.
  amount     Int
  createdAt  DateTime          @default(now())

  @@index([customerId, createdAt])
}
