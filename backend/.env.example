# SQLite database location (Prisma).
#
# connection_limit=1: SQLite has a single database-wide write lock (docs/adr/0001),
# so one connection is the correct pool shape — concurrent consumes queue cleanly
# in Prisma's pool and run one at a time, instead of many connections fighting the
# write lock. pool_timeout gives queued requests room to wait rather than erroring.
DATABASE_URL="file:./prisma/dev.db?connection_limit=1&pool_timeout=30"
PORT=4000
